# Скопируйте в .env: cp .env.example .env
# Только для локальной разработки. Значения должны совпадать со строками подключения в README и на портале.

# Публичный origin браузера (Redis Insight, согласованность с Kibana)
PORTAL_PUBLIC_ORIGIN=http://db.local

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# --- pgAdmin ---
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin

# --- MongoDB ---
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin

# --- mongo-express (HTTP Basic) ---
MONGO_EXPRESS_BASICAUTH_USERNAME=admin
MONGO_EXPRESS_BASICAUTH_PASSWORD=admin

# --- Elasticsearch (пользователь elastic) ---
ELASTIC_PASSWORD=elastic_local

# Пароль пользователя kibana_system в Elasticsearch (Kibana → ES)
KIBANA_SYSTEM_PASSWORD=kibana_local

# Публичный URL Kibana за nginx (как в адресной строке браузера)
KIBANA_PUBLIC_URL=http://db.local/kibana

# --- Valkey (ACL, не пользователь default) ---
VALKEY_USER=valkey
VALKEY_PASSWORD=valkey_local

# --- Qdrant ---
QDRANT_API_KEY=qdrant_local

# Порт портала на хосте (nginx)
PORTAL_HOST_PORT=80

# Пароли MONGO_INITDB_* и PostgreSQL применяются при первом создании volume;
# смена значений в .env не переинициализирует уже существующие данные — нужен docker compose down -v (с потерей данных).
